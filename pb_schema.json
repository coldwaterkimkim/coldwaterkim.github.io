{
  "collections": [
    {
      "name": "posts",
      "type": "base",
      "fields": [
        { "name": "title", "type": "text", "required": true, "min": 1, "max": 200 },
        { "name": "slug", "type": "text", "required": true, "min": 1, "max": 200, "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        { "name": "content", "type": "editor", "required": false },
        { "name": "excerpt", "type": "text", "required": false, "max": 500 },
        { "name": "status", "type": "select", "required": true, "values": ["draft", "published"], "maxSelect": 1 },
        { "name": "published_at", "type": "date", "required": false },
        { "name": "created", "type": "autodate", "onCreate": true, "onUpdate": false },
        { "name": "updated", "type": "autodate", "onCreate": true, "onUpdate": true }
      ],
      "indexes": [
        "CREATE UNIQUE INDEX `idx_posts_slug` ON `posts` (`slug`)",
        "CREATE INDEX `idx_posts_status` ON `posts` (`status`)",
        "CREATE INDEX `idx_posts_published_at` ON `posts` (`published_at`)"
      ],
      "listRule": "status = 'published' || @request.auth.id != ''",
      "viewRule": "status = 'published' || @request.auth.id != ''",
      "createRule": "@request.auth.id != ''",
      "updateRule": "@request.auth.id != ''",
      "deleteRule": "@request.auth.id != ''"
    },
    {
      "name": "daily_entries",
      "type": "base",
      "fields": [
        { "name": "title", "type": "text", "required": true, "min": 1, "max": 200 },
        { "name": "slug", "type": "text", "required": true, "min": 1, "max": 200, "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        { "name": "day_key", "type": "text", "required": true, "min": 10, "max": 10, "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        { "name": "content", "type": "editor", "required": false },
        { "name": "excerpt", "type": "text", "required": false, "max": 500 },
        { "name": "status", "type": "select", "required": true, "values": ["draft", "published"], "maxSelect": 1 },
        { "name": "published_at", "type": "date", "required": false },
        { "name": "created", "type": "autodate", "onCreate": true, "onUpdate": false },
        { "name": "updated", "type": "autodate", "onCreate": true, "onUpdate": true }
      ],
      "indexes": [
        "CREATE UNIQUE INDEX `idx_daily_entries_slug` ON `daily_entries` (`slug`)",
        "CREATE INDEX `idx_daily_entries_day_key` ON `daily_entries` (`day_key`)",
        "CREATE INDEX `idx_daily_entries_status` ON `daily_entries` (`status`)",
        "CREATE INDEX `idx_daily_entries_published_at` ON `daily_entries` (`published_at`)"
      ],
      "listRule": "status = 'published' || @request.auth.id != ''",
      "viewRule": "status = 'published' || @request.auth.id != ''",
      "createRule": "@request.auth.id != ''",
      "updateRule": "@request.auth.id != ''",
      "deleteRule": "@request.auth.id != ''"
    },
    {
      "name": "guestbook",
      "type": "base",
      "fields": [
        { "name": "name", "type": "text", "required": true, "min": 1, "max": 50 },
        { "name": "message", "type": "text", "required": true, "min": 1, "max": 1000 },
        { "name": "display_date", "type": "date", "required": false },
        { "name": "created", "type": "autodate", "onCreate": true, "onUpdate": false },
        { "name": "updated", "type": "autodate", "onCreate": true, "onUpdate": true }
      ],
      "listRule": "",
      "viewRule": "",
      "createRule": "",
      "updateRule": null,
      "deleteRule": "@request.auth.id != ''"
    },
    {
      "name": "site_settings",
      "type": "base",
      "fields": [
        { "name": "key", "type": "text", "required": true, "min": 1, "max": 100 },
        { "name": "value", "type": "text", "required": false },
        { "name": "created", "type": "autodate", "onCreate": true, "onUpdate": false },
        { "name": "updated", "type": "autodate", "onCreate": true, "onUpdate": true }
      ],
      "indexes": ["CREATE UNIQUE INDEX `idx_settings_key` ON `site_settings` (`key`)"],
      "listRule": "",
      "viewRule": "",
      "createRule": "@request.auth.id != ''",
      "updateRule": "@request.auth.id != ''",
      "deleteRule": "@request.auth.id != ''"
    },
    {
      "name": "visitor_sessions",
      "type": "base",
      "fields": [
        { "name": "session_key", "type": "text", "required": true, "min": 64, "max": 64, "pattern": "^[a-f0-9]{64}$" },
        { "name": "day_key", "type": "text", "required": true, "min": 10, "max": 10, "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        { "name": "created", "type": "autodate", "onCreate": true, "onUpdate": false },
        { "name": "updated", "type": "autodate", "onCreate": true, "onUpdate": true }
      ],
      "indexes": [
        "CREATE UNIQUE INDEX `idx_visitor_sessions_session_key` ON `visitor_sessions` (`session_key`)",
        "CREATE INDEX `idx_visitor_sessions_day_key` ON `visitor_sessions` (`day_key`)"
      ],
      "listRule": "",
      "viewRule": "",
      "createRule": "",
      "updateRule": "@request.auth.id != ''",
      "deleteRule": "@request.auth.id != ''"
    },
    {
      "name": "post_views",
      "type": "base",
      "fields": [
        { "name": "view_key", "type": "text", "required": true, "min": 64, "max": 64, "pattern": "^[a-f0-9]{64}$" },
        { "name": "post_id", "type": "text", "required": true, "min": 1, "max": 32 },
        { "name": "post_slug", "type": "text", "required": false, "max": 200 },
        { "name": "day_key", "type": "text", "required": true, "min": 10, "max": 10, "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        { "name": "created", "type": "autodate", "onCreate": true, "onUpdate": false },
        { "name": "updated", "type": "autodate", "onCreate": true, "onUpdate": true }
      ],
      "indexes": [
        "CREATE UNIQUE INDEX `idx_post_views_view_key` ON `post_views` (`view_key`)",
        "CREATE INDEX `idx_post_views_post_id` ON `post_views` (`post_id`)",
        "CREATE INDEX `idx_post_views_post_slug` ON `post_views` (`post_slug`)",
        "CREATE INDEX `idx_post_views_day_key` ON `post_views` (`day_key`)"
      ],
      "listRule": "@request.auth.id != ''",
      "viewRule": "@request.auth.id != ''",
      "createRule": "",
      "updateRule": null,
      "deleteRule": "@request.auth.id != ''"
    },
    {
      "name": "programs",
      "type": "base",
      "fields": [
        { "name": "title", "type": "text", "required": true, "min": 1, "max": 160 },
        { "name": "slug", "type": "text", "required": true, "min": 1, "max": 120, "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        { "name": "status", "type": "select", "required": true, "values": ["released", "beta", "prototype", "unreleased", "archived"], "maxSelect": 1 },
        { "name": "platform", "type": "text", "required": false, "max": 160 },
        { "name": "tagline", "type": "text", "required": false, "max": 200 },
        { "name": "story_intro", "type": "text", "required": false, "max": 500 },
        { "name": "why", "type": "text", "required": true, "min": 1, "max": 1200 },
        { "name": "pain_point", "type": "text", "required": true, "min": 1, "max": 1200 },
        { "name": "story_detail", "type": "text", "required": false, "max": 5000 },
        {
          "name": "cover_image",
          "type": "file",
          "required": false,
          "maxSelect": 1,
          "maxSize": 20971520,
          "mimeTypes": ["image/jpeg", "image/png", "image/gif", "image/webp"]
        },
        {
          "name": "download_files",
          "type": "file",
          "required": false,
          "maxSelect": 8,
          "maxSize": 209715200,
          "mimeTypes": []
        },
        { "name": "primary_link_label", "type": "text", "required": false, "max": 80 },
        { "name": "primary_link_url", "type": "url", "required": false, "max": 1000 },
        { "name": "is_public", "type": "bool", "required": true },
        { "name": "created", "type": "autodate", "onCreate": true, "onUpdate": false },
        { "name": "updated", "type": "autodate", "onCreate": true, "onUpdate": true }
      ],
      "indexes": [
        "CREATE UNIQUE INDEX `idx_programs_slug` ON `programs` (`slug`)",
        "CREATE INDEX `idx_programs_public` ON `programs` (`is_public`)",
        "CREATE INDEX `idx_programs_status` ON `programs` (`status`)"
      ],
      "listRule": "is_public = true || @request.auth.id != ''",
      "viewRule": "is_public = true || @request.auth.id != ''",
      "createRule": "@request.auth.id != ''",
      "updateRule": "@request.auth.id != ''",
      "deleteRule": "@request.auth.id != ''"
    },
    {
      "name": "nasajab",
      "type": "base",
      "fields": [
        { "name": "memo", "type": "text", "required": false, "max": 600 },
        { "name": "source_url", "type": "url", "required": false, "max": 1000 },
        { "name": "display_at", "type": "date", "required": false },
        {
          "name": "image",
          "type": "file",
          "required": true,
          "maxSelect": 1,
          "maxSize": 20971520,
          "mimeTypes": ["image/jpeg", "image/png", "image/gif", "image/webp"]
        },
        { "name": "is_public", "type": "bool", "required": true },
        { "name": "created", "type": "autodate", "onCreate": true, "onUpdate": false },
        { "name": "updated", "type": "autodate", "onCreate": true, "onUpdate": true }
      ],
      "indexes": [
        "CREATE INDEX `idx_nasajab_public` ON `nasajab` (`is_public`)",
        "CREATE INDEX `idx_nasajab_display_at` ON `nasajab` (`display_at`)"
      ],
      "listRule": "is_public = true || @request.auth.id != ''",
      "viewRule": "is_public = true || @request.auth.id != ''",
      "createRule": "@request.auth.id != ''",
      "updateRule": "@request.auth.id != ''",
      "deleteRule": "@request.auth.id != ''"
    },
    {
      "name": "media",
      "type": "base",
      "fields": [
        {
          "name": "file",
          "type": "file",
          "required": true,
          "maxSelect": 1,
          "maxSize": 209715200,
          "mimeTypes": ["image/jpeg", "image/png", "image/gif", "image/webp", "video/mp4", "video/webm", "video/quicktime", "video/x-m4v", "audio/mpeg", "audio/mp3", "application/pdf"]
        },
        { "name": "alt_text", "type": "text", "required": false, "max": 200 },
        { "name": "caption", "type": "text", "required": false, "max": 500 },
        { "name": "created", "type": "autodate", "onCreate": true, "onUpdate": false },
        { "name": "updated", "type": "autodate", "onCreate": true, "onUpdate": true }
      ],
      "listRule": "",
      "viewRule": "",
      "createRule": "@request.auth.id != ''",
      "updateRule": "@request.auth.id != ''",
      "deleteRule": "@request.auth.id != ''"
    }
  ],
  "users_collection_policy": {
    "note": "PocketBase creates the users auth collection by default. Keep public signup disabled for this site. The admin login ID is stored in the built-in name field and must have a unique index before name can be used as a password auth identity field.",
    "passwordAuth": {
      "enabled": true,
      "identityFields": ["email", "name"]
    },
    "indexes": [
      "CREATE UNIQUE INDEX `idx_email__pb_users_auth_` ON `users` (`email`) WHERE `email` != ''",
      "CREATE UNIQUE INDEX `idx_name__pb_users_auth_` ON `users` (`name`) WHERE `name` != ''"
    ],
    "authRule": "",
    "createRule": null,
    "listRule": "id = @request.auth.id",
    "viewRule": "id = @request.auth.id",
    "updateRule": "id = @request.auth.id",
    "deleteRule": null
  }
}
